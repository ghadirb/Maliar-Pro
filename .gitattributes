# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
gradlew text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.kt text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.sh text eol=lf

# Declare files that will always have CRLF line endings on checkout
*.bat text eol=crlf
*.cmd text eol=crlf
gradlew.bat text eol=crlf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.aar binary
*.apk binary
